{
  "expo": {
    "name": "Dedupe — Liberá Espacio",
    "slug": "dedupe-android",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.puglit.dedupe",
      "permissions": ["READ_MEDIA_IMAGES", "READ_MEDIA_VIDEO", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "plugins": [
      ["expo-media-library", { "photosPermission": "Dedupe necesita leer tus fotos para encontrar duplicados.", "savePhotosPermission": "Permitir gestionar tus fotos.", "isAccessMediaLocationEnabled": true }]
    ]
  }
}
