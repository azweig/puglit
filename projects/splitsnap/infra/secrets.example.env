# Puglit Spine — secrets template. Copy to .env (dev) / set as Fly secrets (prod).
# NEVER commit real values. Only the modules you enabled need their block.

# ── Core: Database (Supabase via the Supavisor POOLER — IPv4, see BLUEPRINT §6) ──
# Use the pooler host + user "dbuser.projectref" (session mode 5432), NOT db.<ref>.supabase.co
POSTGRES_HOST=aws-1-<region>.pooler.supabase.com
POSTGRES_PORT=5432
POSTGRES_USER=<dbuser>.<projectref>
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
DATABASE_URL=postgresql://<dbuser>.<projectref>:<pass>@aws-1-<region>.pooler.supabase.com:5432/postgres

# ── Core: Auth ──
JWT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=

# ── Core: Deploy / crons ──
CRON_PRIMARY_MACHINE_ID=          # set after first Fly deploy
NODE_ENV=production

# ── Core: Observability ──
SENTRY_DSN=

# ── Module: payments ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# MERCADOPAGO_ACCESS_TOKEN=
# MP_WEBHOOK_SECRET=

# ── Module: email-lifecycle ──
RESEND_API_KEY=
EMAIL_FROM=
# IMAP bounce poller (optional):
# IMAP_HOST=
# IMAP_USER=
# IMAP_PASSWORD=

# ── Module: ai-layer ──
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Module: engine (external compute service) ──
# MODEL_SERVICE_URL=
# MODEL_SERVICE_API_KEY=

# ── Module: analytics ──
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=
