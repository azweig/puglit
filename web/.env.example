# ───────────────────────────────────────────────────────────────────────────
# Puglit — environment
# Copy to .env.local and fill what you need. NEVER commit real secrets.
# ───────────────────────────────────────────────────────────────────────────

# ── LLM provider ────────────────────────────────────────────────────────────
# Puglit is provider-agnostic. With NOTHING set below it runs 100% LOCAL and FREE
# on Ollama + Gemma (just `ollama serve` + `ollama pull gemma2`). BYOK to go cloud.
# See docs/PROVIDERS.md for the full guide + model presets (Gemma/Hermes/DeepSeek/Qwen/Llama).

# Which provider to use: ollama | openai | gemini | anthropic | custom
# (If unset: uses a key/base-url if present, else defaults to local `ollama`.)
PUGLIT_PROVIDER=ollama

# Model per tier (premium = architecture/code/design, balanced = specs/fixers, cheap = extraction).
# Defaults are sensible per provider; override here. Examples for Ollama:
PUGLIT_MODEL_PREMIUM=gemma2:27b
PUGLIT_MODEL_BALANCED=gemma2
PUGLIT_MODEL_CHEAP=gemma2:2b

# Keys (only for paid/cloud providers — Ollama needs none).
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# ANTHROPIC_API_KEY=sk-ant-...
# PUGLIT_API_KEY=...            # generic fallback key for `custom`/OpenAI-compat gateways

# Base URL override (for `custom`, OpenRouter, Together, vLLM, a remote Ollama, etc.)
# PUGLIT_BASE_URL=http://localhost:11434/v1
# OPENAI_BASE_URL=...           # legacy alias, still honored

# MIX providers per tier (advanced): e.g. local Gemma everywhere but Claude for the heavy tier.
# PUGLIT_PREMIUM_PROVIDER=anthropic
# PUGLIT_PREMIUM_API_KEY=sk-ant-...
# PUGLIT_PREMIUM_BASE_URL=...

# Tuning
# PUGLIT_VISION=always|never    # force image analysis on/off (some Ollama models like llava/gemma3 see)
# PUGLIT_SEND_TEMPERATURE=always|never
# PUGLIT_MAX_TOKENS=8192        # Anthropic max output tokens

# ── App / data ──────────────────────────────────────────────────────────────
# DATABASE_URL=postgres://...   # Postgres (jobs + generated projects)
# CRON_SECRET=...               # protects /api/cron/*
# GITHUB_TOKEN=...              # to push generated projects to a repo
# GITHUB_REPO=owner/repo
